# Copy this file to .env and fill in real values. Never commit .env itself.

# --- Postgres ---
POSTGRES_USER=ekip
POSTGRES_PASSWORD=ekip_password
POSTGRES_DB=ekip_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- LLM / Embedding providers (fill in what you plan to use) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Auth ---
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Qdrant (already have this section, just confirming values) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=ekip_chunks

# --- Embeddings / Chunking ---
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
CHUNK_SIZE=500
CHUNK_OVERLAP=50
